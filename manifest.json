{
  "manifest_version": 3,
  "name": "MarkN Video Speed",
  "version": "0.1.0",
  "description": "HTML5 video/audio の再生速度をキーボードショートカットとポップアップで操作するシンプルな拡張機能",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_title": "MarkN Video Speed",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "js": [
        "src/lib/storage.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
